{% extends "base.html.j2" %}

{% block title %}{{ product.name }} — {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <!-- Breadcrumb -->
  <nav class="breadcrumb mb-6">
    <a href="{{ store_root }}">{{ site.name }}</a>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <a href="{{ store_root }}">{{ product.category }}</a>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="text-gray-400 truncate max-w-xs">{{ product.name }}</span>
  </nav>

  <!-- Product layout: 2-col on desktop, stacked on mobile -->
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10 lg:gap-16">

    <!-- Left: Image -->
    <div>
      <div class="product-detail-image" style="background: {{ product.bg_color }}0e;">
        {% if product.image_url %}
        <img src="{{ product.image_url }}" alt="{{ product.name }}"
             class="max-w-full" style="max-height:280px;object-fit:contain;">
        {% else %}
        <img src="../static/placeholder.svg" alt="{{ product.name }}"
             class="max-w-full" style="max-height:280px;object-fit:contain;">
        {% endif %}
      </div>
      <!-- Thumbnail row -->
      <div class="flex gap-2 mt-4">
        <div class="w-16 h-16 rounded-lg border-2 cursor-pointer flex items-center justify-center"
             style="border-color: var(--accent); background: {{ product.bg_color }}12;">
          {% if product.image_url %}
          <img src="{{ product.image_url }}" alt="" class="w-12 h-12 object-contain">
          {% else %}
          <img src="../static/placeholder.svg" alt="" class="w-10 h-10 object-contain">
          {% endif %}
        </div>
      </div>
    </div>

    <!-- Right: Details -->
    <div class="flex flex-col gap-5">

      <!-- Category + signal -->
      <div class="flex items-center gap-2 flex-wrap">
        <span class="category-badge">{{ product.category }}</span>
        {% if product.signal == "strong_buy" %}
        <span class="signal-badge signal-strong">&#9733; Top Pick</span>
        {% elif product.signal == "consider" %}
        <span class="signal-badge signal-consider">&#10003; Καλή Επιλογή</span>
        {% endif %}
      </div>

      <!-- Name -->
      <h1 class="text-2xl sm:text-3xl font-extrabold leading-tight tracking-tight text-gray-900">
        {{ product.name }}
      </h1>

      <!-- Price block -->
      <div class="flex items-baseline gap-3">
        <span class="text-3xl font-extrabold" style="color: var(--accent)">
          €{{ "%.2f" | format(product.price) }}
        </span>
        <span class="text-sm text-gray-400">συμπ. ΦΠΑ</span>
      </div>

      <!-- Divider -->
      <hr class="border-gray-100">

      <!-- Availability -->
      <div class="flex items-center gap-2 text-sm text-green-600 font-medium">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        Άμεσα διαθέσιμο
      </div>

      <!-- Quantity + Add to Cart -->
      <div class="flex items-center gap-3">
        <div class="flex items-center border border-gray-200 rounded-lg overflow-hidden">
          <button onclick="adjustQty(-1)"
            class="w-10 h-11 flex items-center justify-center text-gray-500 hover:bg-gray-50 transition-colors text-lg font-medium">
            −
          </button>
          <span id="qty-display"
            class="w-10 h-11 flex items-center justify-center text-sm font-semibold border-x border-gray-200">
            1
          </span>
          <button onclick="adjustQty(1)"
            class="w-10 h-11 flex items-center justify-center text-gray-500 hover:bg-gray-50 transition-colors text-lg font-medium">
            +
          </button>
        </div>
        <button class="btn-add-cart flex-1"
          onclick="addToCartQty('{{ product.id }}', {{ product.name | tojson }}, {{ product.price }})">
          Προσθήκη στο καλάθι
        </button>
      </div>

      <!-- Features -->
      <div class="bg-gray-50 rounded-xl p-4 grid grid-cols-2 gap-3 text-xs text-gray-500">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
          <span>Αποστολή 1–3 εργάσιμες</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
          <span>Ασφαλής πληρωμή</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
          <span>Κάρτα · Αντικαταβολή</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          <span>Δωρεάν επιστροφή 14 ημ.</span>
        </div>
      </div>

      <!-- External reference -->
      {% if product.skroutz_url %}
      <a href="{{ product.skroutz_url }}" target="_blank" rel="noopener"
         class="inline-flex items-center gap-1.5 text-xs text-blue-500 hover:text-blue-600 transition-colors">
        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
        </svg>
        Δες τιμές στο Skroutz
      </a>
      {% endif %}

    </div>
  </div>

  <!-- Back link -->
  <div class="mt-12">
    <a href="{{ store_root }}"
       class="inline-flex items-center gap-2 text-sm font-medium transition-colors"
       style="color: var(--accent)">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Επιστροφή στον κατάλογο
    </a>
  </div>

</div>
{% endblock %}

{% block scripts %}
<script>
  var _qty = 1;
  function adjustQty(delta) {
    _qty = Math.max(1, _qty + delta);
    document.getElementById("qty-display").textContent = _qty;
  }
  function addToCartQty(id, name, price) {
    for (var i = 0; i < _qty; i++) addToCart(id, name, price);
  }
</script>
{% endblock %}

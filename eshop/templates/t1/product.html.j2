{% extends "base.html.j2" %}

{% block title %}{{ product.name }} — {{ site.name }}{% endblock %}

{% block head %}
<style>
/* ── T1 PRODUCT PAGE ──────────────────────────────────────── */
.prod-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  align-items: start;
}
@media (min-width: 768px) {
  .prod-layout {
    grid-template-columns: 5fr 7fr;
    gap: 56px;
  }
  .prod-image-col {
    position: sticky;
    top: 80px; /* below header 56px + sticky bar */
  }
}

.prod-image-box {
  aspect-ratio: 3/4;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px;
}
.prod-image-box img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

.prod-divider {
  border: none;
  border-top: 1px solid var(--border);
  margin: 0;
}

.prod-price {
  font-family: var(--font-display);
  font-feature-settings: "tnum";
  font-size: 2.4rem;
  color: var(--ink);
  line-height: 1;
  letter-spacing: -0.02em;
}

.qty-ctrl {
  display: flex;
  align-items: center;
  border: 1px solid var(--border);
  border-radius: 4px;
  overflow: hidden;
}
.qty-btn {
  width: 40px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  font-weight: 500;
  background: white;
  color: var(--ink);
  border: none;
  cursor: pointer;
  transition: background 0.1s;
}
.qty-btn:hover { background: var(--surface); }
.qty-num {
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  font-weight: 600;
  color: var(--ink);
  border-left: 1px solid var(--border);
  border-right: 1px solid var(--border);
}

.btn-add-lg {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border-radius: 4px;
  font-size: 0.875rem;
  font-weight: 600;
  color: white;
  background: var(--accent);
  border: none;
  cursor: pointer;
  transition: opacity 0.12s;
  letter-spacing: 0.01em;
}
.btn-add-lg:hover  { opacity: 0.9; }
.btn-add-lg:active { opacity: 0.78; }

/* Skroutz data panel */
.skz-panel {
  border-top: 1px solid var(--border);
  padding-top: 18px;
}
.skz-title {
  font-size: 0.62rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin-bottom: 12px;
}
.skz-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-size: 0.8rem;
  color: var(--ink-muted);
  padding: 6px 0;
  border-bottom: 1px solid var(--border);
}
.skz-row:last-of-type { border-bottom: none; }
.skz-val {
  font-family: var(--font-display);
  font-feature-settings: "tnum";
  font-size: 0.9rem;
  color: var(--ink);
}

.ean-tag {
  font-family: 'Courier New', monospace;
  font-size: 0.67rem;
  letter-spacing: 0.12em;
  color: var(--ink-muted);
  border: 1px solid var(--border);
  border-radius: 3px;
  padding: 3px 8px;
  display: inline-block;
}
</style>
{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-6 py-8">

  <!-- Breadcrumb -->
  <nav class="breadcrumb mb-8">
    <a href="{{ store_root }}">{{ site.name }}</a>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <a href="{{ store_root }}">{{ product.category }}</a>
    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="truncate max-w-xs" style="color: var(--ink-muted);">{{ product.name }}</span>
  </nav>

  <div class="prod-layout">

    <!-- LEFT: Image (sticky on desktop) -->
    <div class="prod-image-col">
      <div class="prod-image-box" style="background: {{ product.bg_color }}07;">
        {% if product.image_url %}
        <img src="{{ product.image_url }}" alt="{{ product.name }}">
        {% else %}
        <img src="../static/placeholder.svg" alt="{{ product.name }}">
        {% endif %}
      </div>
      {% if product.barcode %}
      <div class="mt-3 flex items-center gap-2">
        <span style="font-size: 0.65rem; color: var(--ink-muted);">EAN</span>
        <span class="ean-tag">{{ product.barcode }}</span>
      </div>
      {% endif %}
    </div>

    <!-- RIGHT: Details -->
    <div style="display: flex; flex-direction: column; gap: 20px;">

      <!-- Category + signal -->
      <div style="display: flex; align-items: center; gap: 8px; flex-wrap: wrap;">
        <span style="font-size: 0.6rem; font-weight: 700; letter-spacing: 0.1em;
                     text-transform: uppercase; color: var(--accent);">{{ product.category }}</span>
        {% if product.signal == "strong_buy" %}
        <span style="font-size: 0.6rem; font-weight: 700; letter-spacing: 0.06em;
                     text-transform: uppercase; padding: 2px 8px; border-radius: 2px;
                     background: var(--accent); color: white;">Top Pick</span>
        {% elif product.signal == "consider" %}
        <span style="font-size: 0.6rem; font-weight: 700; letter-spacing: 0.06em;
                     text-transform: uppercase; padding: 2px 8px; border-radius: 2px;
                     background: #F4F4F5; color: var(--ink-muted);">Αξίζει</span>
        {% endif %}
      </div>

      <!-- Product name -->
      <h1 class="t1-numeral" style="font-size: clamp(1.5rem, 3.5vw, 2.25rem); font-weight: 700;
                 line-height: 1.12; letter-spacing: -0.02em; color: var(--ink);">
        {{ product.name }}
      </h1>

      <!-- Real reviews -->
      {% if product.review_count > 0 %}
      <div style="display: flex; align-items: center; gap: 8px; font-size: 0.82rem;
                  color: var(--ink-muted);">
        <span style="color: #ca8a04; font-size: 0.9rem;">★</span>
        <span style="font-weight: 600; color: var(--ink);">{{ "%.1f" | format(product.rating) }}</span>
        <span>&middot; {{ product.review_count }} κριτικές</span>
        {% if product.skroutz_url %}
        <a href="{{ product.skroutz_url }}" target="_blank" rel="noopener"
           style="font-size: 0.72rem; color: var(--accent);" class="hover:underline">από Skroutz</a>
        {% endif %}
      </div>
      {% endif %}

      <hr class="prod-divider">

      <!-- Price -->
      <div style="display: flex; align-items: baseline; gap: 12px;">
        <span class="prod-price">€{{ "%.2f" | format(product.price) }}</span>
        {% if product.retail_price > product.price and product.retail_price > 0 %}
        <span style="font-size: 0.875rem; text-decoration: line-through; color: var(--ink-muted);">
          €{{ "%.2f" | format(product.retail_price) }}
        </span>
        {% endif %}
        <span style="font-size: 0.72rem; color: var(--ink-muted);">συμπ. ΦΠΑ 24%</span>
      </div>

      <!-- Stock -->
      <div style="display: flex; align-items: center; gap: 8px; font-size: 0.82rem;
                  font-weight: 500; color: #16a34a;">
        <div style="width: 7px; height: 7px; border-radius: 50%; background: #16a34a;
                    flex-shrink: 0;"></div>
        Άμεσα διαθέσιμο — αποστολή εντός 24ω
      </div>

      <hr class="prod-divider">

      <!-- Qty + Add to cart -->
      <div style="display: flex; align-items: center; gap: 12px;">
        <div class="qty-ctrl">
          <button class="qty-btn" onclick="adjustQty(-1)">−</button>
          <div id="qty-display" class="qty-num">1</div>
          <button class="qty-btn" onclick="adjustQty(1)">+</button>
        </div>
        <button class="btn-add-lg"
                onclick="addToCartQty('{{ product.id }}', {{ product.name | tojson }}, {{ product.price }})">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          Προσθήκη στο καλάθι
        </button>
      </div>

      <!-- Delivery line (flat text, no icon grid) -->
      <div style="font-size: 0.75rem; color: var(--ink-muted); line-height: 1.8;">
        Αποστολή 1–3 εργάσιμες &thinsp;&middot;&thinsp; Κάρτα &amp; Αντικαταβολή
        &thinsp;&middot;&thinsp; Επιστροφή εντός 14 ημερών
      </div>

      <!-- Skroutz comparison panel -->
      {% if product.shop_count > 0 %}
      <div class="skz-panel">
        <div class="skz-title">Δεδομένα αγοράς &middot; Skroutz.gr</div>
        <div class="skz-row">
          <span>Διαθέσιμο σε</span>
          <span class="skz-val">{{ product.shop_count }} καταστήματα</span>
        </div>
        {% if product.review_count > 0 %}
        <div class="skz-row">
          <span>Βαθμολογία</span>
          <span class="skz-val">{{ "%.1f" | format(product.rating) }} / 5</span>
        </div>
        <div class="skz-row">
          <span>Κριτικές</span>
          <span class="skz-val">{{ product.review_count }}</span>
        </div>
        {% endif %}
        {% if product.skroutz_url %}
        <div style="margin-top: 12px;">
          <a href="{{ product.skroutz_url }}" target="_blank" rel="noopener"
             style="font-size: 0.72rem; font-weight: 600; color: var(--accent);"
             class="hover:underline">
            Δες όλα τα καταστήματα στο Skroutz.gr →
          </a>
        </div>
        {% endif %}
      </div>
      {% endif %}

    </div>
  </div>

  <!-- Back link -->
  <div class="mt-12">
    <a href="{{ store_root }}"
       style="display: inline-flex; align-items: center; gap: 6px; font-size: 0.82rem;
              font-weight: 500; color: var(--ink-muted);"
       class="hover:underline">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Επιστροφή στον κατάλογο
    </a>
  </div>

</div>
{% endblock %}

{% block scripts %}
<script>
  var _qty = 1;
  function adjustQty(delta) {
    _qty = Math.max(1, _qty + delta);
    document.getElementById("qty-display").textContent = _qty;
  }
  function addToCartQty(id, name, price) {
    for (var i = 0; i < _qty; i++) addToCart(id, name, price);
  }
</script>
{% endblock %}

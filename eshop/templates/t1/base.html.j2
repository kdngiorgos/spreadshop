<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ site.name }}{% endblock %}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=Inter+Tight:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ static_root }}/style.css">
  <style>
    :root {
      --accent:       {{ site.accent_color }};
      --accent-dark:  {{ site.accent_dark }};
      --surface:      #FCFCFC;
      --ink:          #0F1014;
      --ink-muted:    #71717A;
      --border:       #E4E4E7;
      --font-display: 'Fraunces', Georgia, serif;
      --font-body:    'Inter Tight', system-ui, sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: var(--font-body);
      background: var(--surface);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; color: inherit; }
    .t1-numeral {
      font-family: var(--font-display);
      font-feature-settings: "tnum";
    }
  </style>
  {% block head %}{% endblock %}
</head>
<body>

  <!-- ── UTILITY BAR ──────────────────────────────────────────────── -->
  <div class="hidden sm:block text-xs py-1.5"
       style="background: var(--ink); color: rgba(255,255,255,0.45);">
    <div class="max-w-7xl mx-auto px-6 flex items-center justify-between">
      <span style="letter-spacing: 0.06em; font-size: 0.65rem; text-transform: uppercase;">{{ site.name }}</span>
      <span>Δωρεάν αποστολή &gt; 50€ &thinsp;&middot;&thinsp; Επιστροφές 14 ημ. &thinsp;&middot;&thinsp; SSL</span>
    </div>
  </div>

  <!-- ── HEADER ────────────────────────────────────────────────────── -->
  <header class="sticky top-0 z-40 bg-white" style="border-bottom: 1px solid var(--border);">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex items-center h-14 gap-6">

        <!-- Store name / logo -->
        <a href="{{ store_root }}" class="flex-shrink-0">
          {% if site.logo_url %}
          <img src="{{ static_root }}/{{ site.logo_url }}" alt="{{ site.name }}"
               class="h-8 w-auto object-contain">
          {% else %}
          <span class="t1-numeral" style="font-size: 1.1rem; font-weight: 600; color: var(--ink); letter-spacing: -0.02em;">
            {{ site.name }}
          </span>
          {% endif %}
        </a>

        <!-- Search -->
        <div class="flex-1 max-w-md">
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 pointer-events-none"
                 fill="none" stroke="currentColor" viewBox="0 0 24 24"
                 style="color: var(--ink-muted);">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
            </svg>
            <input id="search-input" type="text" placeholder="Αναζήτηση..."
              class="w-full pl-9 pr-4 py-2 text-sm focus:outline-none bg-white"
              style="border: 1px solid var(--border); border-radius: 4px; color: var(--ink);">
          </div>
        </div>

        <!-- Cart -->
        <button id="cart-btn" onclick="toggleCart()"
          class="flex-shrink-0 flex items-center gap-2 text-sm font-medium"
          style="color: var(--ink);">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <span class="hidden sm:inline">Καλάθι</span>
          <span id="cart-count"
            class="text-xs font-bold rounded-full w-5 h-5 inline-flex items-center justify-center"
            style="background: var(--accent); color: white;">0</span>
        </button>

      </div>
    </div>
  </header>

  <!-- ── MAIN ──────────────────────────────────────────────────────── -->
  <main class="min-h-screen">
    {% block content %}{% endblock %}
  </main>

  <!-- ── FOOTER ────────────────────────────────────────────────────── -->
  <footer class="bg-white mt-16" style="border-top: 1px solid var(--border);">
    <div class="max-w-7xl mx-auto px-6 pt-10 pb-8">

      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-8">
        <div class="col-span-2 sm:col-span-1">
          <span class="t1-numeral text-sm font-semibold" style="color: var(--ink);">{{ site.name }}</span>
          <p class="text-xs mt-2 leading-relaxed" style="color: var(--ink-muted);">{{ site.tagline }}</p>
        </div>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--ink-muted); font-size: 0.62rem;">Εξυπηρέτηση</h5>
          <ul class="space-y-2 text-xs" style="color: var(--ink-muted);">
            <li><a href="#" class="hover:underline">Παρακολούθηση παραγγελίας</a></li>
            <li><a href="#" class="hover:underline">Επιστροφές &amp; αλλαγές</a></li>
            <li><a href="#" class="hover:underline">Συχνές ερωτήσεις</a></li>
          </ul>
        </div>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--ink-muted); font-size: 0.62rem;">Αποστολές</h5>
          <ul class="space-y-2 text-xs" style="color: var(--ink-muted);">
            <li><a href="#" class="hover:underline">Τρόποι αποστολής</a></li>
            <li><a href="#" class="hover:underline">Χρόνοι παράδοσης</a></li>
            <li><a href="#" class="hover:underline">Αντικαταβολή</a></li>
          </ul>
        </div>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--ink-muted); font-size: 0.62rem;">Εταιρεία</h5>
          <ul class="space-y-2 text-xs" style="color: var(--ink-muted);">
            <li><a href="#" class="hover:underline">Σχετικά με εμάς</a></li>
            <li><a href="#" class="hover:underline">Επικοινωνία</a></li>
            <li><a href="#" class="hover:underline">Όροι χρήσης</a></li>
          </ul>
        </div>
      </div>

      <div class="flex flex-wrap items-center justify-between gap-3 pt-5"
           style="border-top: 1px solid var(--border);">
        <span class="text-xs" style="color: var(--ink-muted);">
          &copy; {{ year }} {{ site.name }}. Όλα τα δικαιώματα διατηρούνται.
        </span>
        <span class="text-xs font-mono" style="color: var(--ink-muted); letter-spacing: 0.06em;">
          {{ product_count }} προϊόντα &thinsp;&middot;&thinsp; {{ category_count }} κατηγορίες
        </span>
      </div>

    </div>
  </footer>

  <!-- ── CART TOAST ────────────────────────────────────────────────── -->
  <div id="cart-toast"
    class="fixed bottom-5 right-5 bg-white p-4 text-sm hidden z-50 flex items-center gap-3 max-w-xs"
    style="border: 1px solid var(--border); border-radius: 6px;
           box-shadow: 0 4px 20px rgba(15,16,20,0.07);">
    <div class="w-6 h-6 flex items-center justify-center flex-shrink-0"
         style="background: var(--accent); border-radius: 4px;">
      <svg class="w-3.5 h-3.5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
    <div>
      <div class="font-semibold" style="font-size: 0.72rem; color: var(--ink);">Προστέθηκε στο καλάθι</div>
      <div id="cart-toast-text" class="truncate max-w-44"
           style="font-size: 0.7rem; margin-top: 1px; color: var(--ink-muted);"></div>
    </div>
  </div>

  <script src="{{ static_root }}/catalog.js"></script>
  {% block scripts %}{% endblock %}
</body>
</html>

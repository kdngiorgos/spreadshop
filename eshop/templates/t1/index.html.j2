{% extends "base.html.j2" %}

{% block title %}{{ site.name }} — Κατάλογος{% endblock %}

{% block head %}
<style>
/* ── T1 "EDITORIAL" INDEX ──────────────────────────────────── */

/* Override shared .filter-pill — editorial underline tab style */
.filter-pill {
  display: inline-block;
  padding: 10px 0;
  margin-right: 22px;
  font-size: 0.78rem;
  font-weight: 500;
  color: var(--ink-muted);
  cursor: pointer;
  border: none;
  border-bottom: 2px solid transparent;
  background: none;
  white-space: nowrap;
  flex-shrink: 0;
  transition: color 0.12s, border-color 0.12s;
  user-select: none;
}
.filter-pill:hover { color: var(--ink); }
.filter-pill.active {
  color: var(--ink);
  border-bottom-color: var(--accent);
  font-weight: 600;
}

/* 12-col asymmetric editorial grid */
#product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1px;
  background: var(--border);
}
@media (min-width: 640px) {
  #product-grid { grid-template-columns: repeat(4, 1fr); }
}
@media (min-width: 1024px) {
  #product-grid { grid-template-columns: repeat(12, 1fr); }
  .product-card             { grid-column: span 3; }
  .product-card.card-feature { grid-column: span 6; }
}

/* Override shared .product-card */
.product-card {
  background: var(--surface);
  display: flex;
  flex-direction: column;
  border-radius: 0;
  box-shadow: none;
  border: none;
  transition: background 0.14s;
}
.product-card:hover { background: white; }

/* Image area */
.ed-img {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
  aspect-ratio: 4/5;
}
.product-card.card-feature .ed-img { aspect-ratio: 3/2; }

.ed-img img {
  width: 55%;
  height: 55%;
  object-fit: contain;
  transition: transform 0.28s ease;
}
.product-card:hover .ed-img img { transform: scale(1.04); }
.product-card.card-feature .ed-img img { width: 42%; height: 42%; }

/* Signal badges */
.ed-badge {
  position: absolute;
  top: 10px;
  left: 10px;
  font-size: 0.57rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  padding: 2px 7px;
  border-radius: 2px;
}
.ed-badge-strong { background: var(--accent); color: white; }
.ed-badge-ok     { background: #F4F4F5; color: var(--ink-muted); }

/* Card body */
.ed-body {
  padding: 14px 16px 18px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}
.ed-cat {
  font-size: 0.59rem;
  font-weight: 700;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--accent);
}
.ed-name {
  font-size: 0.82rem;
  font-weight: 500;
  line-height: 1.38;
  color: var(--ink);
  flex: 1;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.product-card.card-feature .ed-name {
  font-size: 0.98rem;
  -webkit-line-clamp: 3;
}

/* Review row */
.ed-review {
  font-size: 0.63rem;
  color: var(--ink-muted);
}

/* Price row */
.ed-price-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 6px;
  margin-top: 8px;
  padding-top: 10px;
  border-top: 1px solid var(--border);
}
.ed-price {
  font-family: var(--font-display);
  font-feature-settings: "tnum";
  font-size: 1.1rem;
  color: var(--ink);
  line-height: 1;
}
.product-card.card-feature .ed-price { font-size: 1.3rem; }
.ed-was {
  font-size: 0.7rem;
  text-decoration: line-through;
  color: var(--ink-muted);
}

/* Quiet add-to-cart link */
.ed-add {
  font-size: 0.7rem;
  font-weight: 600;
  color: var(--accent);
  background: none;
  border: none;
  cursor: pointer;
  padding: 0;
  letter-spacing: 0.01em;
  white-space: nowrap;
}
.ed-add:hover { text-decoration: underline; }
</style>
{% endblock %}

{% block content %}

<!-- ── EDITORIAL HERO ──────────────────────────────────────────────── -->
<section class="max-w-7xl mx-auto px-6 pt-12 pb-10">
  <div class="max-w-2xl">
    <div style="width: 28px; height: 2px; background: var(--accent); margin-bottom: 16px;"></div>
    <h1 class="t1-numeral" style="font-size: clamp(2rem, 5vw, 3.25rem); font-weight: 700;
               line-height: 1.08; letter-spacing: -0.025em; color: var(--ink);">
      {{ site.headline }}
    </h1>
    <p style="margin-top: 16px; font-size: 0.875rem; line-height: 1.7;
              color: var(--ink-muted); max-width: 440px;">
      {{ site.subheadline }}
    </p>
  </div>
</section>

<!-- ── CATEGORY FILTER BAR ─────────────────────────────────────────── -->
<div class="sticky top-14 z-30 bg-white" style="border-bottom: 1px solid var(--border);">
  <div class="max-w-7xl mx-auto px-6">
    <div class="flex items-center overflow-x-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
      <button class="filter-pill active" data-category="all">
        Όλα <span style="opacity: 0.5;">({{ product_count }})</span>
      </button>
      {% for cat in categories %}
      <button class="filter-pill" data-category="{{ cat.name }}">
        {{ cat.name }} <span style="opacity: 0.5;">({{ cat.count }})</span>
      </button>
      {% endfor %}
      <span id="results-count" class="flex-shrink-0 text-xs ml-auto"
            style="color: var(--ink-muted); padding-left: 16px; white-space: nowrap;">
        {{ product_count }} προϊόντα
      </span>
    </div>
  </div>
</div>

<!-- ── PRODUCT GRID ─────────────────────────────────────────────────── -->
<div class="max-w-7xl mx-auto px-6 pt-6 pb-16">

  <div id="product-grid">
    {% for p in products %}
    <div class="product-card{% if loop.index0 % 5 == 0 %} card-feature{% endif %}"
         data-category="{{ p.category }}"
         data-name="{{ p.name | lower }}">

      <!-- Image -->
      <a href="product/{{ p.slug }}.html" class="block">
        <div class="ed-img" style="background: {{ p.bg_color }}09;">
          {% if p.image_url %}
          <img src="{{ p.image_url }}" alt="{{ p.name }}" loading="lazy">
          {% else %}
          <img src="static/placeholder.svg" alt="{{ p.name }}" loading="lazy">
          {% endif %}
          {% if p.signal == "strong_buy" %}
          <div class="ed-badge ed-badge-strong">Top Pick</div>
          {% elif p.signal == "consider" %}
          <div class="ed-badge ed-badge-ok">Αξίζει</div>
          {% endif %}
        </div>
      </a>

      <!-- Info -->
      <div class="ed-body">
        <div class="ed-cat">{{ p.category }}</div>
        <a href="product/{{ p.slug }}.html" class="ed-name">{{ p.name }}</a>

        {% if p.review_count > 0 %}
        <div class="ed-review">
          <span style="color: #ca8a04;">★</span>
          {{ "%.1f" | format(p.rating) }} &middot; {{ p.review_count }} κριτικές
        </div>
        {% endif %}

        <div class="ed-price-row">
          <div style="display: flex; align-items: baseline; gap: 6px;">
            <span class="ed-price">€{{ "%.2f" | format(p.price) }}</span>
            {% if p.retail_price > p.price and p.retail_price > 0 %}
            <span class="ed-was">€{{ "%.2f" | format(p.retail_price) }}</span>
            {% endif %}
          </div>
          <button class="ed-add"
            onclick="addToCart('{{ p.id }}', {{ p.name | tojson }}, {{ p.price }})">
            + Καλάθι
          </button>
        </div>

        {% if p.shop_count > 0 %}
        <div style="font-size: 0.61rem; color: var(--ink-muted); margin-top: 3px;">
          Σε {{ p.shop_count }} καταστήματα &middot; Skroutz
        </div>
        {% endif %}

      </div>
    </div>
    {% endfor %}
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="empty-state" style="display: none;">
    <svg class="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <p class="font-semibold mt-2" style="color: var(--ink-muted);">Δεν βρέθηκαν προϊόντα</p>
    <p class="text-xs mt-1" style="color: var(--ink-muted);">Δοκιμάστε άλλη αναζήτηση</p>
  </div>

</div>
{% endblock %}

{% extends "base.html.j2" %}

{% block title %}{{ site.name }} — Κατάλογος Προϊόντων{% endblock %}

{% block content %}

<!-- ── HERO BANNER ────────────────────────────────────────────── -->
<section class="relative overflow-hidden" style="background: linear-gradient(135deg, var(--accent) 0%, var(--accent-dark) 100%)">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14 sm:py-20">
    <div class="text-white max-w-xl">
      <p class="text-xs font-semibold uppercase tracking-widest mb-3 opacity-75">{{ site.name }}</p>
      <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight tracking-tight mb-4">
        {{ site.headline }}
      </h1>
      <p class="text-sm sm:text-base opacity-80 leading-relaxed">
        {{ site.subheadline }}
      </p>
      <div class="mt-8 flex items-center gap-4 text-xs font-semibold">
        <span class="bg-white bg-opacity-20 rounded-full px-4 py-1.5">
          {{ product_count }} Προϊόντα
        </span>
        <span class="bg-white bg-opacity-20 rounded-full px-4 py-1.5">
          {{ category_count }} Κατηγορίες
        </span>
      </div>
    </div>
  </div>
  <!-- Decorative circles -->
  <div class="absolute right-0 top-0 w-80 h-80 rounded-full opacity-10 -translate-y-1/2 translate-x-1/4"
       style="background: white"></div>
  <div class="absolute right-24 bottom-0 w-48 h-48 rounded-full opacity-10 translate-y-1/2"
       style="background: white"></div>
</section>

<!-- ── CATEGORY FILTERS ───────────────────────────────────────── -->
<div class="bg-white border-b border-gray-100 sticky top-16 z-30">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-3">
    <div class="flex items-center gap-4">
      <div class="category-strip flex-1">
        <button class="filter-pill active" data-category="all">
          Όλα ({{ product_count }})
        </button>
        {% for cat in categories %}
        <button class="filter-pill" data-category="{{ cat.name }}">
          {{ cat.name }} ({{ cat.count }})
        </button>
        {% endfor %}
      </div>
      <span id="results-count" class="flex-shrink-0 text-xs text-gray-400">
        {{ product_count }} προϊόντα
      </span>
    </div>
  </div>
</div>

<!-- ── PRODUCT GRID ───────────────────────────────────────────── -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

  <div id="product-grid"
       class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 xl:grid-cols-5 gap-4">
    {% for p in products %}
    <div class="product-card"
         data-category="{{ p.category }}"
         data-name="{{ p.name | lower }}">

      <!-- Image -->
      <a href="product/{{ p.slug }}.html" class="block">
        <div class="product-image-wrap" style="background: {{ p.bg_color }}12;">
          {% if p.image_url %}
          <img src="{{ p.image_url }}" alt="{{ p.name }}" loading="lazy">
          {% else %}
          <img src="static/placeholder.svg" alt="{{ p.name }}" loading="lazy">
          {% endif %}
          {% if p.signal == "strong_buy" %}
          <div class="absolute top-2 left-2">
            <span class="signal-badge signal-strong">&#9733; Top Pick</span>
          </div>
          {% elif p.signal == "consider" %}
          <div class="absolute top-2 left-2">
            <span class="signal-badge signal-consider">&#10003; Αξίζει</span>
          </div>
          {% endif %}
        </div>
      </a>

      <!-- Info -->
      <div class="p-3 flex flex-col gap-2 flex-1">
        <div>
          <span class="category-badge">{{ p.category }}</span>
        </div>
        <a href="product/{{ p.slug }}.html"
           class="text-sm font-medium text-gray-900 leading-snug hover:text-[color:var(--accent)] transition-colors line-clamp-2">
          {{ p.name }}
        </a>
        <div class="mt-auto pt-1 flex items-end justify-between gap-2">
          <div>
            <div class="price-main">€{{ "%.2f" | format(p.price) }}</div>
          </div>
        </div>
        <button class="btn-add-cart"
          onclick="addToCart('{{ p.id }}', {{ p.name | tojson }}, {{ p.price }})">
          + Καλάθι
        </button>
      </div>
    </div>
    {% endfor %}
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="empty-state" style="display:none">
    <svg class="w-16 h-16" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <p class="font-semibold text-gray-500 mt-2">Δεν βρέθηκαν προϊόντα</p>
    <p class="mt-1">Δοκιμάστε διαφορετική αναζήτηση ή κατηγορία</p>
  </div>

</div>
{% endblock %}

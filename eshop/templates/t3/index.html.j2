{% extends "base.html.j2" %}

{% block title %}{{ site.name }} — Κατάλογος{% endblock %}

{% block head %}
<style>
/* ── T3 "AGORA MODERN" CATALOG ─────────────────────────────── */

/* Override shared .filter-pill for the market look */
.filter-pill {
  flex-shrink: 0;
  padding: 5px 13px;
  border-radius: 5px;
  font-size: 0.75rem;
  font-weight: 600;
  cursor: pointer;
  border: 1px solid var(--border);
  background: white;
  color: var(--ink-muted);
  transition: background 0.12s, color 0.12s, border-color 0.12s;
  white-space: nowrap;
  user-select: none;
}
.filter-pill:hover { border-color: var(--accent); color: var(--accent); }
.filter-pill.active { background: var(--accent); border-color: var(--accent); color: white; }

/* Deals strip */
.deals-scroll {
  display: flex;
  gap: 10px;
  overflow-x: auto;
  padding-bottom: 4px;
  scrollbar-width: none;
  -ms-overflow-style: none;
}
.deals-scroll::-webkit-scrollbar { display: none; }

.deal-card {
  flex-shrink: 0;
  background: white;
  border-radius: 10px;
  border: 1px solid var(--border);
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px 16px;
  min-width: 210px;
  max-width: 240px;
  color: var(--ink);
  transition: border-color 0.13s;
}
.deal-card:hover { border-color: var(--accent); }
.deal-card-img {
  width: 50px;
  height: 50px;
  border-radius: 8px;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.deal-card-img img { width: 40px; height: 40px; object-fit: contain; }
.deal-name {
  font-size: 0.72rem;
  font-weight: 600;
  line-height: 1.3;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
.deal-price { font-family: var(--font-display); font-size: 1rem; margin-top: 3px; color: var(--ink); }
.deal-meta { font-size: 0.65rem; margin-top: 1px; color: var(--ink-muted); }

/* Asymmetric product grid */
#product-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 8px;
}
@media (min-width: 640px) {
  #product-grid { grid-template-columns: repeat(4, 1fr); gap: 12px; }
}
@media (min-width: 1024px) {
  #product-grid { grid-template-columns: repeat(12, 1fr); gap: 14px; }
  .product-card             { grid-column: span 2; }
  .product-card.card-anchor { grid-column: span 4; }
}

/* Base card */
.product-card {
  background: white;
  border-radius: 10px;
  border: 1px solid var(--border);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: border-color 0.13s;
}
.product-card:hover { border-color: var(--accent); }

/* Card image */
.mkt-card-img {
  position: relative;
  aspect-ratio: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
}
.mkt-card-img img {
  width: 65%;
  height: 65%;
  object-fit: contain;
  transition: transform 0.22s ease;
}
.product-card:hover .mkt-card-img img { transform: scale(1.04); }
.product-card.card-anchor .mkt-card-img { aspect-ratio: 4/3; }
.product-card.card-anchor .mkt-card-img img { width: 55%; height: 55%; }

/* Card text area */
.mkt-card-body {
  padding: 10px 12px 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  flex: 1;
}
.mkt-cat {
  font-size: 0.63rem;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--accent);
}
.mkt-name {
  font-size: 0.78rem;
  font-weight: 500;
  line-height: 1.35;
  color: var(--ink);
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  flex: 1;
}
.product-card.card-anchor .mkt-name {
  font-size: 0.88rem;
  -webkit-line-clamp: 3;
}

/* Badges */
.mkt-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  font-size: 0.58rem;
  font-weight: 700;
  letter-spacing: 0.04em;
  padding: 2px 7px;
  border-radius: 4px;
}
.mkt-badge-top  { background: var(--accent); color: white; }
.mkt-badge-ok   { background: #fef9c3; color: #854d0e; }

/* Review row */
.mkt-review {
  font-size: 0.67rem;
  color: var(--ink-muted);
  display: flex;
  align-items: center;
  gap: 3px;
}
.mkt-star { color: #eab308; }

/* Price row */
.mkt-price-row {
  display: flex;
  align-items: baseline;
  gap: 6px;
  margin-top: auto;
  padding-top: 4px;
}
.mkt-price {
  font-family: var(--font-display);
  font-size: 1.2rem;
  color: var(--ink);
  font-feature-settings: "tnum";
  line-height: 1;
}
.product-card.card-anchor .mkt-price { font-size: 1.4rem; }
.mkt-retail-crossed {
  font-size: 0.75rem;
  text-decoration: line-through;
  color: var(--ink-muted);
}
.mkt-skroutz-line {
  font-size: 0.63rem;
  color: var(--ink-muted);
  margin-top: 2px;
}

/* Add to cart */
.mkt-add-btn {
  width: 100%;
  margin-top: 8px;
  padding: 8px;
  border-radius: 6px;
  font-size: 0.77rem;
  font-weight: 700;
  color: white;
  background: var(--accent);
  cursor: pointer;
  border: none;
  transition: opacity 0.12s;
}
.mkt-add-btn:hover  { opacity: 0.88; }
.mkt-add-btn:active { opacity: 0.75; }
</style>
{% endblock %}

{% block content %}

<!-- ── CATEGORY FILTER BAR ─────────────────────────────────────────── -->
<div class="sticky top-16 z-30 bg-white" style="border-bottom: 1px solid var(--border);">
  <div class="max-w-7xl mx-auto px-4 py-2">
    <div class="flex items-center gap-2 overflow-x-auto" style="scrollbar-width: none; -ms-overflow-style: none;">
      <button class="filter-pill active" data-category="all">
        Όλα <span class="opacity-60 ml-0.5">({{ product_count }})</span>
      </button>
      {% for cat in categories %}
      <button class="filter-pill" data-category="{{ cat.name }}">
        {{ cat.name }} <span class="opacity-60 ml-0.5">({{ cat.count }})</span>
      </button>
      {% endfor %}
      <span id="results-count" class="flex-shrink-0 text-xs ml-auto pl-2" style="color: var(--ink-muted);">
        {{ product_count }} προϊόντα
      </span>
    </div>
  </div>
</div>

<!-- ── DEALS STRIP ──────────────────────────────────────────────────── -->
{% set top_deals = products
    | rejectattr("signal", "equalto", "not_found")
    | rejectattr("signal", "equalto", "skip")
    | selectattr("shop_count", "gt", 0)
    | list %}
{% if top_deals %}
<div class="max-w-7xl mx-auto px-4 pt-6 pb-2">
  <div class="flex items-baseline gap-3 mb-3">
    <h2 class="text-sm font-bold" style="color: var(--ink);">Κορυφαία αποτελέσματα</h2>
    <span class="text-xs" style="color: var(--ink-muted);">{{ top_deals | length }} επιλεγμένα βάσει αγοράς</span>
  </div>
  <div class="deals-scroll">
    {% for p in top_deals[:10] %}
    <a href="product/{{ p.slug }}.html" class="deal-card">
      <div class="deal-card-img" style="background: {{ p.bg_color }}10;">
        {% if p.image_url %}
        <img src="{{ p.image_url }}" alt="{{ p.name }}" loading="lazy">
        {% else %}
        <img src="static/placeholder.svg" alt="{{ p.name }}" loading="lazy">
        {% endif %}
      </div>
      <div class="min-w-0">
        <div class="deal-name">{{ p.name }}</div>
        <div class="deal-price">€{{ "%.2f" | format(p.price) }}</div>
        <div class="deal-meta">
          {% if p.shop_count > 0 %}Σε {{ p.shop_count }} καταστήματα{% endif %}
        </div>
      </div>
    </a>
    {% endfor %}
  </div>
</div>
{% endif %}

<!-- ── PRODUCT GRID ─────────────────────────────────────────────────── -->
<div class="max-w-7xl mx-auto px-4 pt-6 pb-14">

  <div id="product-grid">
    {% for p in products %}
    <div class="product-card{% if loop.index0 % 5 == 0 %} card-anchor{% endif %}"
         data-category="{{ p.category }}"
         data-name="{{ p.name | lower }}">

      <!-- Image -->
      <a href="product/{{ p.slug }}.html" class="block">
        <div class="mkt-card-img" style="background: {{ p.bg_color }}0d;">
          {% if p.image_url %}
          <img src="{{ p.image_url }}" alt="{{ p.name }}" loading="lazy">
          {% else %}
          <img src="static/placeholder.svg" alt="{{ p.name }}" loading="lazy">
          {% endif %}
          {% if p.signal == "strong_buy" %}
          <div class="mkt-badge mkt-badge-top">&#9733; Top Pick</div>
          {% elif p.signal == "consider" %}
          <div class="mkt-badge mkt-badge-ok">&#10003; Αξίζει</div>
          {% endif %}
        </div>
      </a>

      <!-- Info -->
      <div class="mkt-card-body">
        <div class="mkt-cat">{{ p.category }}</div>
        <a href="product/{{ p.slug }}.html" class="mkt-name" style="text-decoration: none;">{{ p.name }}</a>

        <!-- Real reviews — only shown when Skroutz provided them -->
        {% if p.review_count > 0 %}
        <div class="mkt-review">
          <span class="mkt-star">&#9733;</span>
          {{ "%.1f" | format(p.rating) }} &middot; {{ p.review_count }} κριτικές
        </div>
        {% endif %}

        <!-- Price (with strikethrough catalog price when market undercuts it) -->
        <div class="mkt-price-row">
          <span class="mkt-price">€{{ "%.2f" | format(p.price) }}</span>
          {% if p.retail_price > p.price and p.retail_price > 0 %}
          <span class="mkt-retail-crossed">€{{ "%.2f" | format(p.retail_price) }}</span>
          {% endif %}
        </div>

        <!-- Skroutz market data line -->
        {% if p.shop_count > 0 %}
        <div class="mkt-skroutz-line">Σε {{ p.shop_count }} καταστήματα &middot; Skroutz</div>
        {% endif %}

        <button class="mkt-add-btn"
          onclick="addToCart('{{ p.id }}', {{ p.name | tojson }}, {{ p.price }})">
          + Καλάθι
        </button>
      </div>

    </div>
    {% endfor %}
  </div>

  <!-- Empty state -->
  <div id="empty-state" class="empty-state" style="display: none;">
    <svg class="w-14 h-14" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
            d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
    </svg>
    <p class="font-semibold mt-2" style="color: var(--ink-muted);">Δεν βρέθηκαν προϊόντα</p>
    <p class="text-xs mt-1" style="color: var(--ink-muted);">Δοκιμάστε άλλη αναζήτηση</p>
  </div>

</div>
{% endblock %}

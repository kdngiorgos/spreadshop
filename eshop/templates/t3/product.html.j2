{% extends "base.html.j2" %}

{% block title %}{{ product.name }} — {{ site.name }}{% endblock %}

{% block head %}
<style>
/* ── T3 PRODUCT PAGE ──────────────────────────────────────── */
.product-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: 32px;
  align-items: start;
}
@media (min-width: 768px) {
  .product-layout {
    grid-template-columns: 5fr 7fr;
    gap: 48px;
  }
  .product-image-col {
    position: sticky;
    top: 88px; /* below header ~64px + utility ~24px */
  }
}

.product-image-box {
  border-radius: 14px;
  border: 1px solid var(--border);
  background: var(--surface);
  min-height: 320px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40px;
}
.product-image-box img {
  max-width: 260px;
  max-height: 260px;
  object-fit: contain;
}

.product-signal {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-size: 0.72rem;
  font-weight: 700;
  padding: 3px 9px;
  border-radius: 4px;
}
.signal-strong  { background: var(--accent); color: white; }
.signal-consider{ background: #fef9c3; color: #854d0e; }

.product-price {
  font-family: var(--font-display);
  font-size: 2.6rem;
  color: var(--ink);
  font-feature-settings: "tnum";
  line-height: 1;
  letter-spacing: -0.01em;
}

.skroutz-panel {
  border-radius: 10px;
  border: 1px solid var(--border);
  background: white;
  padding: 14px 16px;
}
.skroutz-panel-title {
  font-size: 0.7rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ink-muted);
  margin-bottom: 10px;
}
.skroutz-stat-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  font-size: 0.82rem;
  color: var(--ink-muted);
  padding: 5px 0;
  border-bottom: 1px solid var(--border);
}
.skroutz-stat-row:last-of-type { border-bottom: none; }
.skroutz-stat-val {
  font-family: var(--font-display);
  font-size: 0.95rem;
  color: var(--ink);
  font-feature-settings: "tnum";
}

.ean-display {
  font-family: 'Courier New', monospace;
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  color: var(--ink-muted);
  background: white;
  border: 1px solid var(--border);
  border-radius: 5px;
  padding: 4px 10px;
  display: inline-block;
}

.product-feature-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}
.product-feature-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.75rem;
  color: var(--ink-muted);
  background: white;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 10px 12px;
}

.qty-control {
  display: flex;
  align-items: center;
  border: 1.5px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
}
.qty-btn {
  width: 40px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.1rem;
  font-weight: 600;
  background: white;
  color: var(--ink);
  cursor: pointer;
  border: none;
  transition: background 0.1s;
}
.qty-btn:hover { background: var(--surface); }
.qty-display {
  width: 40px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.875rem;
  font-weight: 700;
  color: var(--ink);
  border-left: 1.5px solid var(--border);
  border-right: 1.5px solid var(--border);
}

.btn-add-cart-lg {
  flex: 1;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  border-radius: 8px;
  font-size: 0.9rem;
  font-weight: 700;
  color: white;
  background: var(--accent);
  cursor: pointer;
  border: none;
  transition: opacity 0.12s;
}
.btn-add-cart-lg:hover  { opacity: 0.9; }
.btn-add-cart-lg:active { opacity: 0.78; }
</style>
{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 py-6">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-1.5 text-xs mb-6" style="color: var(--ink-muted);">
    <a href="{{ store_root }}" class="hover:underline font-medium" style="color: var(--ink-muted);">{{ site.name }}</a>
    <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <a href="{{ store_root }}" class="hover:underline" style="color: var(--ink-muted);">{{ product.category }}</a>
    <svg class="w-3 h-3 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="truncate max-w-xs">{{ product.name }}</span>
  </nav>

  <!-- Product layout: sticky image left, details right -->
  <div class="product-layout">

    <!-- LEFT: Image column (sticky on desktop) -->
    <div class="product-image-col">
      <div class="product-image-box" style="background: {{ product.bg_color }}0a;">
        {% if product.image_url %}
        <img src="{{ product.image_url }}" alt="{{ product.name }}">
        {% else %}
        <img src="../static/placeholder.svg" alt="{{ product.name }}">
        {% endif %}
      </div>
      <!-- EAN barcode reference -->
      {% if product.barcode %}
      <div class="mt-3 flex items-center gap-2">
        <span class="text-xs" style="color: var(--ink-muted);">EAN</span>
        <span class="ean-display">{{ product.barcode }}</span>
      </div>
      {% endif %}
    </div>

    <!-- RIGHT: Details column -->
    <div class="flex flex-col gap-5">

      <!-- Category + signal badges -->
      <div class="flex items-center gap-2 flex-wrap">
        <span class="text-xs font-bold uppercase tracking-widest" style="color: var(--accent);">{{ product.category }}</span>
        {% if product.signal == "strong_buy" %}
        <span class="product-signal signal-strong">&#9733; Κορυφαία Επιλογή</span>
        {% elif product.signal == "consider" %}
        <span class="product-signal signal-consider">&#10003; Καλή Επιλογή</span>
        {% endif %}
      </div>

      <!-- Product name -->
      <h1 class="text-2xl sm:text-3xl font-bold leading-snug" style="color: var(--ink);">
        {{ product.name }}
      </h1>

      <!-- Real reviews — only when Skroutz data is available -->
      {% if product.review_count > 0 %}
      <div class="flex items-center gap-2 text-sm" style="color: var(--ink-muted);">
        <span style="color: #eab308; font-size: 1rem; letter-spacing: 0.05em;">&#9733;</span>
        <span class="font-semibold" style="color: var(--ink);">{{ "%.1f" | format(product.rating) }}</span>
        <span>&middot; {{ product.review_count }} κριτικές</span>
        {% if product.skroutz_url %}
        <a href="{{ product.skroutz_url }}" target="_blank" rel="noopener"
           class="text-xs hover:underline" style="color: var(--accent);">από Skroutz</a>
        {% endif %}
      </div>
      {% endif %}

      <!-- Price block -->
      <div class="flex items-baseline gap-3">
        <span class="product-price">€{{ "%.2f" | format(product.price) }}</span>
        {% if product.retail_price > product.price and product.retail_price > 0 %}
        <span class="text-sm line-through" style="color: var(--ink-muted);">€{{ "%.2f" | format(product.retail_price) }}</span>
        {% endif %}
        <span class="text-xs" style="color: var(--ink-muted);">συμπ. ΦΠΑ 24%</span>
      </div>

      <!-- Stock -->
      <div class="flex items-center gap-2 text-sm font-semibold" style="color: #16a34a;">
        <div class="w-2 h-2 rounded-full bg-green-500 flex-shrink-0"></div>
        Άμεσα διαθέσιμο — αποστολή εντός 24ω
      </div>

      <hr style="border-color: var(--border); margin: 0;">

      <!-- Qty + Add to cart -->
      <div class="flex items-center gap-3">
        <div class="qty-control">
          <button class="qty-btn" onclick="adjustQty(-1)">−</button>
          <div id="qty-display" class="qty-display">1</div>
          <button class="qty-btn" onclick="adjustQty(1)">+</button>
        </div>
        <button class="btn-add-cart-lg"
                onclick="addToCartQty('{{ product.id }}', {{ product.name | tojson }}, {{ product.price }})">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          Προσθήκη στο καλάθι
        </button>
      </div>

      <!-- Delivery features -->
      <div class="product-feature-grid">
        <div class="product-feature-item">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--accent);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
          <span>Αποστολή 1–3 εργάσιμες</span>
        </div>
        <div class="product-feature-item">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--accent);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
          </svg>
          <span>Επιστροφή εντός 14 ημερών</span>
        </div>
        <div class="product-feature-item">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--accent);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
          <span>Κάρτα &middot; Αντικαταβολή</span>
        </div>
        <div class="product-feature-item">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="color: var(--accent);">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          <span>SSL &amp; Ασφαλής πληρωμή</span>
        </div>
      </div>

      <!-- Skroutz comparison panel (only when market data exists) -->
      {% if product.shop_count > 0 %}
      <div class="skroutz-panel">
        <div class="skroutz-panel-title">Δεδομένα αγοράς &middot; Skroutz.gr</div>
        <div class="skroutz-stat-row">
          <span>Διαθέσιμο σε</span>
          <span class="skroutz-stat-val">{{ product.shop_count }} καταστήματα</span>
        </div>
        {% if product.review_count > 0 %}
        <div class="skroutz-stat-row">
          <span>Βαθμολογία αγοραστών</span>
          <span class="skroutz-stat-val">{{ "%.1f" | format(product.rating) }} / 5</span>
        </div>
        <div class="skroutz-stat-row">
          <span>Αριθμός κριτικών</span>
          <span class="skroutz-stat-val">{{ product.review_count }}</span>
        </div>
        {% endif %}
        {% if product.skroutz_url %}
        <div class="mt-3">
          <a href="{{ product.skroutz_url }}" target="_blank" rel="noopener"
             class="text-xs font-semibold hover:underline" style="color: var(--accent);">
            Δες όλα τα καταστήματα στο Skroutz.gr →
          </a>
        </div>
        {% endif %}
      </div>
      {% endif %}

    </div>
  </div>

  <!-- Back link -->
  <div class="mt-10">
    <a href="{{ store_root }}"
       class="inline-flex items-center gap-1.5 text-sm font-medium hover:underline"
       style="color: var(--ink-muted);">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Επιστροφή στον κατάλογο
    </a>
  </div>

</div>
{% endblock %}

{% block scripts %}
<script>
  var _qty = 1;
  function adjustQty(d) {
    _qty = Math.max(1, _qty + d);
    document.getElementById("qty-display").textContent = _qty;
  }
  function addToCartQty(id, name, price) {
    for (var i = 0; i < _qty; i++) addToCart(id, name, price);
  }
</script>
{% endblock %}

{% extends "base.html.j2" %}

{% block title %}{{ product.name }} — {{ site.name }}{% endblock %}

{% block content %}
<div class="max-w-7xl mx-auto px-4 py-6">

  <!-- Breadcrumb -->
  <nav class="flex items-center gap-1.5 text-xs text-gray-400 mb-6">
    <a href="{{ store_root }}" class="hover:text-gray-700 font-medium">{{ site.name }}</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <a href="{{ store_root }}" class="hover:text-gray-700">{{ product.category }}</a>
    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
    <span class="truncate max-w-xs text-gray-500">{{ product.name }}</span>
  </nav>

  <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
    <div class="grid grid-cols-1 md:grid-cols-2 gap-0">

      <!-- Image -->
      <div class="flex items-center justify-center p-10 border-b md:border-b-0 md:border-r border-gray-100"
           style="background: {{ product.bg_color }}0a; min-height: 340px;">
        {% if product.image_url %}
        <img src="{{ product.image_url }}" alt="{{ product.name }}"
             class="max-w-full object-contain" style="max-height: 260px;">
        {% else %}
        <img src="../static/placeholder.svg" alt="{{ product.name }}"
             class="max-w-full object-contain" style="max-height: 260px;">
        {% endif %}
      </div>

      <!-- Details -->
      <div class="p-8 flex flex-col gap-5">

        <!-- Badges + category -->
        <div class="flex items-center gap-2 flex-wrap">
          <span class="text-xs font-semibold text-gray-500 uppercase tracking-wide">
            {{ product.category }}
          </span>
          {% if product.signal == "strong_buy" %}
          <span class="text-xs font-bold px-2 py-0.5 rounded"
                style="background:var(--accent); color:white">&#9733; Κορυφαία Επιλογή</span>
          {% elif product.signal == "consider" %}
          <span class="text-xs font-bold px-2 py-0.5 rounded bg-yellow-100 text-yellow-700">
            &#10003; Καλή Επιλογή
          </span>
          {% endif %}
        </div>

        <!-- Name -->
        <h1 class="text-2xl font-bold text-gray-900 leading-snug">{{ product.name }}</h1>

        <!-- Rating stub -->
        <div class="flex items-center gap-2">
          <div class="flex text-yellow-400">&#9733;&#9733;&#9733;&#9733;&#9733;</div>
          <span class="text-sm text-gray-500">4.8 ({{ range(15, 120) | random }} αξιολογήσεις)</span>
        </div>

        <!-- Price box -->
        <div class="bg-gray-50 rounded-xl p-4 border border-gray-100">
          <div class="text-3xl font-extrabold" style="color: var(--accent)">
            €{{ "%.2f" | format(product.price) }}
          </div>
          <div class="text-xs text-gray-400 mt-1">Συμπεριλαμβάνεται ΦΠΑ 24%</div>
        </div>

        <!-- Stock status -->
        <div class="flex items-center gap-2 text-sm font-semibold text-green-600">
          <div class="w-2 h-2 rounded-full bg-green-500"></div>
          Άμεσα διαθέσιμο &mdash; αποστολή εντός 24ω
        </div>

        <!-- Qty + add -->
        <div class="flex items-center gap-3">
          <div class="flex items-center border-2 border-gray-200 rounded-lg overflow-hidden">
            <button onclick="adjustQty(-1)"
              class="w-10 h-11 flex items-center justify-center text-gray-600
                     hover:bg-gray-50 transition-colors font-bold text-lg">−</button>
            <span id="qty-display"
              class="w-10 h-11 flex items-center justify-center text-sm font-bold border-x-2 border-gray-200">
              1
            </span>
            <button onclick="adjustQty(1)"
              class="w-10 h-11 flex items-center justify-center text-gray-600
                     hover:bg-gray-50 transition-colors font-bold text-lg">+</button>
          </div>
          <button class="flex-1 h-11 rounded-lg font-bold text-sm text-white flex items-center
                         justify-center gap-2 transition-all hover:opacity-90 active:scale-[0.98]"
                  style="background: var(--accent)"
                  onclick="addToCartQty('{{ product.id }}', {{ product.name | tojson }}, {{ product.price }})">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
            </svg>
            Προσθήκη στο καλάθι
          </button>
        </div>

        <!-- Delivery info strip -->
        <div class="grid grid-cols-2 gap-2">
          <div class="flex items-center gap-2 text-xs text-gray-500 bg-gray-50 rounded-lg p-3">
            <svg class="w-4 h-4 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
            </svg>
            Αποστολή 1–3 εργάσιμες
          </div>
          <div class="flex items-center gap-2 text-xs text-gray-500 bg-gray-50 rounded-lg p-3">
            <svg class="w-4 h-4 flex-shrink-0 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/>
            </svg>
            Επιστροφή εντός 14 ημερών
          </div>
        </div>

        {% if product.skroutz_url %}
        <a href="{{ product.skroutz_url }}" target="_blank" rel="noopener"
           class="text-xs text-blue-500 hover:text-blue-600 inline-flex items-center gap-1">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
          </svg>
          Σύγκριση τιμών στο Skroutz.gr
        </a>
        {% endif %}

      </div>
    </div>
  </div>

  <div class="mt-6">
    <a href="{{ store_root }}"
       class="inline-flex items-center gap-1.5 text-sm font-medium text-gray-500 hover:text-gray-800 transition-colors">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      Επιστροφή στον κατάλογο
    </a>
  </div>

</div>
{% endblock %}

{% block scripts %}
<script>
  var _qty = 1;
  function adjustQty(d) { _qty = Math.max(1, _qty + d); document.getElementById("qty-display").textContent = _qty; }
  function addToCartQty(id, name, price) { for (var i = 0; i < _qty; i++) addToCart(id, name, price); }
</script>
{% endblock %}

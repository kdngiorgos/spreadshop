<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ site.name }}{% endblock %}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ static_root }}/style.css">
  <style>
    :root {
      --accent:      {{ site.accent_color }};
      --accent-dark: {{ site.accent_dark }};
      --surface:     #FAF8F4;
      --ink:         #1A1B1E;
      --ink-muted:   #6B7280;
      --border:      #E8E3DA;
      --font-display:'DM Serif Display', 'Times New Roman', serif;
      --font-body:   'Manrope', 'Noto Sans', system-ui, sans-serif;
    }
    *, *::before, *::after { box-sizing: border-box; }
    body {
      font-family: var(--font-body);
      background: var(--surface);
      color: var(--ink);
      -webkit-font-smoothing: antialiased;
    }
    a { text-decoration: none; }
    .price-numeral {
      font-family: var(--font-display);
      font-feature-settings: "kern" 1;
    }
  </style>
  {% block head %}{% endblock %}
</head>
<body>

  <!-- ── TOP UTILITY BAR ──────────────────────────────────────────── -->
  <div class="hidden sm:block text-xs py-1.5" style="background: var(--ink); color: rgba(255,255,255,0.65);">
    <div class="max-w-7xl mx-auto px-4 flex items-center justify-between gap-4">
      <div class="flex items-center gap-4">
        <span>210 000 0000</span>
        <span style="opacity:0.3">·</span>
        <span>info@{{ site.name | lower | replace(' ', '') }}.gr</span>
      </div>
      <div class="flex items-center gap-4">
        <span>Δωρεάν αποστολή &gt; 50€</span>
        <span style="opacity:0.3">·</span>
        <span>Ασφαλείς πληρωμές</span>
        <span style="opacity:0.3">·</span>
        <span>Επιστροφές 14 ημ.</span>
      </div>
    </div>
  </div>

  <!-- ── HEADER ────────────────────────────────────────────────────── -->
  <header class="sticky top-0 bg-white z-40"
          style="border-bottom: 1px solid var(--border); box-shadow: 0 1px 3px rgba(26,27,30,0.06);">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center h-16 gap-4">

        <!-- Store name / logo -->
        <a href="{{ store_root }}" class="flex-shrink-0">
          {% if site.logo_url %}
          <img src="{{ static_root }}/{{ site.logo_url }}" alt="{{ site.name }}" class="h-9 w-auto object-contain">
          {% else %}
          <span class="text-xl font-semibold price-numeral" style="color: var(--ink); letter-spacing: -0.02em;">
            {{ site.name }}
          </span>
          {% endif %}
        </a>

        <!-- Search (large, market-style) -->
        <div class="flex-1 mx-2 sm:mx-6">
          <div class="flex rounded-lg overflow-hidden" style="border: 1.5px solid var(--accent);">
            <input id="search-input" type="text" placeholder="Τι ψάχνετε;"
              class="flex-1 px-4 py-2.5 text-sm focus:outline-none bg-white min-w-0"
              style="color: var(--ink);">
            <button class="px-4 py-2.5 flex-shrink-0" style="background: var(--accent);">
              <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </button>
          </div>
        </div>

        <!-- Cart -->
        <button id="cart-btn" onclick="toggleCart()"
          class="flex-shrink-0 flex items-center gap-2 px-3 py-2.5 rounded-lg text-white text-sm font-semibold relative"
          style="background: var(--accent);">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <span class="hidden sm:inline font-semibold">Καλάθι</span>
          <span id="cart-count"
            class="absolute -top-1.5 -right-1.5 bg-red-500 text-white text-xs font-bold rounded-full w-5 h-5 flex items-center justify-center leading-none">0</span>
        </button>

      </div>
    </div>
  </header>

  <!-- ── MAIN ──────────────────────────────────────────────────────── -->
  <main class="min-h-screen">
    {% block content %}{% endblock %}
  </main>

  <!-- ── FOOTER ────────────────────────────────────────────────────── -->
  <footer class="bg-white mt-10" style="border-top: 1px solid var(--border);">
    <div class="max-w-7xl mx-auto px-4 pt-10 pb-6">

      <!-- Four-col links -->
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-8">
        <div class="col-span-2 sm:col-span-1">
          <span class="text-base font-semibold price-numeral" style="color: var(--ink);">{{ site.name }}</span>
          <p class="text-xs mt-2 leading-relaxed" style="color: var(--ink-muted);">{{ site.tagline }}</p>
        </div>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--ink-muted);">Εξυπηρέτηση</h5>
          <ul class="space-y-2 text-xs" style="color: var(--ink-muted);">
            <li><a href="#" class="hover:underline">Παρακολούθηση παραγγελίας</a></li>
            <li><a href="#" class="hover:underline">Επιστροφές &amp; αλλαγές</a></li>
            <li><a href="#" class="hover:underline">Συχνές ερωτήσεις</a></li>
          </ul>
        </div>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--ink-muted);">Αποστολές</h5>
          <ul class="space-y-2 text-xs" style="color: var(--ink-muted);">
            <li><a href="#" class="hover:underline">Τρόποι αποστολής</a></li>
            <li><a href="#" class="hover:underline">Χρόνοι παράδοσης</a></li>
            <li><a href="#" class="hover:underline">Αντικαταβολή</a></li>
          </ul>
        </div>
        <div>
          <h5 class="text-xs font-bold uppercase tracking-widest mb-3" style="color: var(--ink-muted);">Η εταιρεία</h5>
          <ul class="space-y-2 text-xs" style="color: var(--ink-muted);">
            <li><a href="#" class="hover:underline">Σχετικά με εμάς</a></li>
            <li><a href="#" class="hover:underline">Επικοινωνία</a></li>
            <li><a href="#" class="hover:underline">Όροι χρήσης</a></li>
          </ul>
        </div>
      </div>

      <!-- Trust wordmarks + copyright -->
      <div class="flex flex-wrap items-center justify-between gap-3 pt-5" style="border-top: 1px solid var(--border);">
        <div class="text-xs font-mono tracking-widest" style="color: var(--ink-muted);">
          VISA &thinsp;&middot;&thinsp; MASTERCARD &thinsp;&middot;&thinsp; PAYPAL &thinsp;&middot;&thinsp; IRIS
          &nbsp;&nbsp;&#124;&nbsp;&nbsp;
          ACS &thinsp;&middot;&thinsp; ELTA &thinsp;&middot;&thinsp; SPEEDEX
          &nbsp;&nbsp;&#124;&nbsp;&nbsp;
          SSL
        </div>
        <div class="text-xs" style="color: var(--ink-muted);">
          &copy; {{ year }} {{ site.name }}. Όλα τα δικαιώματα διατηρούνται.
        </div>
      </div>

    </div>
  </footer>

  <!-- ── CART TOAST (bottom-left, not bottom-right) ───────────────── -->
  <div id="cart-toast"
    class="fixed bottom-5 left-5 rounded-xl shadow-xl bg-white p-4 text-sm hidden z-50 flex items-center gap-3 max-w-xs"
    style="border: 1px solid var(--border);">
    <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
         style="background: var(--accent);">
      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
    <div>
      <div class="font-semibold text-xs" style="color: var(--ink);">Προστέθηκε στο καλάθι</div>
      <div id="cart-toast-text" class="text-xs mt-0.5 truncate max-w-44" style="color: var(--ink-muted);"></div>
    </div>
  </div>

  <script src="{{ static_root }}/catalog.js"></script>
  {% block scripts %}{% endblock %}
</body>
</html>

<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ site.name }}{% endblock %}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family={{ site.font_import }}&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ static_root }}/style.css">
  <style>
    :root {
      --accent:      {{ site.accent_color }};
      --accent-dark: {{ site.accent_dark }};
      --surface:     #f4f6f8;
    }
    body { font-family: {{ site.font_family }}; background: var(--surface); }
  </style>
  {% block head %}{% endblock %}
</head>
<body class="text-gray-900 antialiased">

  <!-- ── INFO BAR ───────────────────────────────────────────────── -->
  <div class="text-white text-xs py-1.5" style="background: var(--accent-dark)">
    <div class="max-w-7xl mx-auto px-4 flex items-center justify-center sm:justify-between gap-4">
      <div class="flex items-center gap-5">
        <span class="flex items-center gap-1.5">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 3a1 1 0 011-1h2.153a1 1 0 01.986.836l.74 4.435a1 1 0 01-.54 1.06l-1.548.773a11.037 11.037 0 006.105 6.105l.774-1.548a1 1 0 011.059-.54l4.435.74a1 1 0 01.836.986V17a1 1 0 01-1 1h-2C7.82 18 2 12.18 2 5V3z"/>
          </svg>
          210 000 0000
        </span>
        <span class="hidden sm:flex items-center gap-1.5">
          <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2.003 5.884L10 9.882l7.997-3.998A2 2 0 0016 4H4a2 2 0 00-1.997 1.884z"/>
            <path d="M18 8.118l-8 4-8-4V14a2 2 0 002 2h12a2 2 0 002-2V8.118z"/>
          </svg>
          info@{{ site.name | lower | replace(' ', '') }}.gr
        </span>
      </div>
      <div class="hidden sm:flex items-center gap-5">
        <span>&#10003; Δωρεάν αποστολή άνω 50€</span>
        <span>&#10003; Ασφαλείς πληρωμές</span>
        <span>&#10003; Επιστροφές 14 ημ.</span>
      </div>
    </div>
  </div>

  <!-- ── HEADER ─────────────────────────────────────────────────── -->
  <header class="sticky top-0 bg-white z-40 shadow-sm">
    <div class="max-w-7xl mx-auto px-4">
      <div class="flex items-center h-16 gap-4">

        <!-- Logo -->
        <a href="{{ store_root }}" class="flex-shrink-0 flex items-center gap-2.5">
          {% if site.logo_url %}
          <img src="{{ static_root }}/{{ site.logo_url }}" alt="{{ site.name }}" class="h-9 w-auto object-contain">
          {% else %}
          <div class="w-9 h-9 rounded-lg flex items-center justify-center text-white font-extrabold text-base"
               style="background: var(--accent)">
            {{ site.name[0] | upper }}
          </div>
          <div>
            <div class="text-base font-bold leading-tight">{{ site.name }}</div>
            <div class="text-xs text-gray-400 leading-none">e-shop</div>
          </div>
          {% endif %}
        </a>

        <!-- Search bar (large) -->
        <div class="flex-1 mx-2">
          <div class="flex rounded-lg overflow-hidden border-2 transition-colors"
               style="border-color: var(--accent)">
            <input id="search-input" type="text" placeholder="Τι ψάχνετε;"
              class="flex-1 px-4 py-2.5 text-sm focus:outline-none bg-white min-w-0">
            <button class="px-5 py-2.5 text-white text-sm font-semibold flex-shrink-0 flex items-center gap-1.5"
                    style="background: var(--accent)">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
              <span class="hidden sm:inline">Αναζήτηση</span>
            </button>
          </div>
        </div>

        <!-- Cart -->
        <button id="cart-btn" onclick="toggleCart()"
          class="flex-shrink-0 flex flex-col items-center gap-0.5 px-4 py-2 rounded-lg
                 text-white transition-all hover:opacity-90 relative"
          style="background: var(--accent)">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
          </svg>
          <span class="text-xs font-semibold leading-none">Καλάθι</span>
          <span id="cart-count"
            class="absolute -top-1.5 -right-1.5 bg-red-500 text-white text-xs
                   font-bold rounded-full w-5 h-5 flex items-center justify-center">0</span>
        </button>

      </div>
    </div>
  </header>

  <!-- ── MAIN ───────────────────────────────────────────────────── -->
  <main class="min-h-screen">
    {% block content %}{% endblock %}
  </main>

  <!-- ── FOOTER ─────────────────────────────────────────────────── -->
  <footer class="bg-white border-t border-gray-200 mt-8">
    <div class="max-w-7xl mx-auto px-4 py-10">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 mb-8">
        <div class="col-span-2 sm:col-span-1">
          <div class="flex items-center gap-2 mb-3">
            <div class="w-8 h-8 rounded-md flex items-center justify-center text-white font-extrabold text-sm"
                 style="background: var(--accent)">
              {{ site.name[0] | upper }}
            </div>
            <span class="font-bold text-base">{{ site.name }}</span>
          </div>
          <p class="text-xs text-gray-400 leading-relaxed">{{ site.tagline }}</p>
        </div>
        <div>
          <h5 class="font-semibold text-sm mb-3">Εξυπηρέτηση</h5>
          <ul class="space-y-2 text-xs text-gray-500">
            <li><a href="#" class="hover:text-gray-800">Παρακολούθηση παραγγελίας</a></li>
            <li><a href="#" class="hover:text-gray-800">Επιστροφές & αλλαγές</a></li>
            <li><a href="#" class="hover:text-gray-800">Συχνές ερωτήσεις</a></li>
          </ul>
        </div>
        <div>
          <h5 class="font-semibold text-sm mb-3">Αποστολές</h5>
          <ul class="space-y-2 text-xs text-gray-500">
            <li><a href="#" class="hover:text-gray-800">Τρόποι αποστολής</a></li>
            <li><a href="#" class="hover:text-gray-800">Χρόνοι παράδοσης</a></li>
            <li><a href="#" class="hover:text-gray-800">Αντικαταβολή</a></li>
          </ul>
        </div>
        <div>
          <h5 class="font-semibold text-sm mb-3">Η εταιρεία</h5>
          <ul class="space-y-2 text-xs text-gray-500">
            <li><a href="#" class="hover:text-gray-800">Σχετικά με εμάς</a></li>
            <li><a href="#" class="hover:text-gray-800">Επικοινωνία</a></li>
            <li><a href="#" class="hover:text-gray-800">Όροι χρήσης</a></li>
          </ul>
        </div>
      </div>

      <!-- Trust badges row -->
      <div class="border-t border-gray-100 pt-6 flex flex-wrap items-center justify-center gap-6">
        <div class="flex items-center gap-2 text-xs text-gray-400">
          <svg class="w-4 h-4 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
          SSL Κρυπτογράφηση
        </div>
        <div class="flex items-center gap-2 text-xs text-gray-400">
          <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
          </svg>
          Visa · Mastercard · PayPal
        </div>
        <div class="flex items-center gap-2 text-xs text-gray-400">
          <svg class="w-4 h-4 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
          </svg>
          ACS · ELTA · Speedex
        </div>
      </div>

      <div class="mt-6 text-center text-xs text-gray-300">
        &copy; {{ year }} {{ site.name }} &mdash; Όλα τα δικαιώματα διατηρούνται
      </div>
    </div>
  </footer>

  <!-- Cart toast -->
  <div id="cart-toast"
    class="fixed bottom-5 right-5 rounded-xl shadow-xl border border-gray-100 bg-white
           p-4 text-sm hidden z-50 flex items-center gap-3 max-w-xs">
    <div class="w-8 h-8 rounded-lg flex items-center justify-center flex-shrink-0"
         style="background: var(--accent)">
      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
    <div>
      <div class="font-semibold text-gray-800 text-xs">Προστέθηκε στο καλάθι</div>
      <div id="cart-toast-text" class="text-gray-500 text-xs mt-0.5 truncate max-w-44"></div>
    </div>
  </div>

  <script src="{{ static_root }}/catalog.js"></script>
  {% block scripts %}{% endblock %}
</body>
</html>

<!DOCTYPE html>
<html lang="el">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{% block title %}{{ site.name }}{% endblock %}</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family={{ site.font_import }}&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="{{ static_root }}/style.css">
  <style>
    :root {
      --accent:      {{ site.accent_color }};
      --accent-dark: {{ site.accent_dark }};
    }
    body { font-family: {{ site.font_family }}; }
  </style>
  {% block head %}{% endblock %}
</head>
<body class="bg-white text-gray-900 antialiased">

  <!-- ── TOP STRIP ──────────────────────────────────────────────── -->
  <div class="border-b border-gray-100">
    <div class="max-w-6xl mx-auto px-6 h-9 flex items-center justify-between text-xs text-gray-400">
      <span>{{ site.name }}</span>
      <span class="hidden sm:flex items-center gap-4">
        <span>Δωρεάν αποστολή άνω των €50</span>
        <span class="text-gray-200">|</span>
        <span>Επιστροφές 14 ημερών</span>
      </span>
    </div>
  </div>

  <!-- ── HEADER ─────────────────────────────────────────────────── -->
  <header class="sticky top-0 bg-white z-40" style="border-bottom: 2px solid var(--accent)">
    <div class="max-w-6xl mx-auto px-6">
      <div class="flex items-center h-16 gap-6">

        <!-- Logo: wordmark style -->
        <a href="{{ store_root }}" class="flex-shrink-0 flex items-center">
          {% if site.logo_url %}
          <img src="{{ static_root }}/{{ site.logo_url }}" alt="{{ site.name }}" class="h-9 w-auto object-contain">
          {% else %}
          <div class="text-xl font-black tracking-tighter leading-none">
            <span style="color: var(--accent)">{{ site.name }}</span>
          </div>
          {% endif %}
        </a>

        <!-- Search: full pill -->
        <div class="flex-1 max-w-sm mx-auto hidden sm:block">
          <div class="relative">
            <input id="search-input" type="text" placeholder="Αναζήτηση…"
              class="w-full py-2 px-4 pr-10 text-sm border border-gray-200 rounded-full
                     focus:outline-none transition-all bg-gray-50 focus:bg-white"
              style="focus:border-color: var(--accent)">
            <button class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 hover:text-gray-600">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
              </svg>
            </button>
          </div>
        </div>

        <div class="ml-auto flex items-center gap-3">
          <!-- Wishlist stub -->
          <button class="hidden sm:flex items-center justify-center w-9 h-9 rounded-full
                         text-gray-400 hover:text-gray-700 hover:bg-gray-50 transition-colors">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.75"
                    d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
            </svg>
          </button>
          <!-- Cart -->
          <button id="cart-btn" onclick="toggleCart()"
            class="relative flex items-center gap-2 py-2 px-4 rounded-full text-sm font-semibold
                   text-white transition-all hover:opacity-90 active:scale-95"
            style="background: var(--accent)">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                    d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/>
            </svg>
            <span id="cart-count"
              class="inline-flex items-center justify-center w-5 h-5 text-xs font-bold
                     rounded-full bg-white"
              style="color: var(--accent)">0</span>
          </button>
        </div>
      </div>
    </div>
  </header>

  <!-- ── MAIN ───────────────────────────────────────────────────── -->
  <main class="min-h-screen">
    {% block content %}{% endblock %}
  </main>

  <!-- ── FOOTER ─────────────────────────────────────────────────── -->
  <footer class="mt-24 border-t border-gray-100">
    <div class="max-w-6xl mx-auto px-6 py-14">
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-10">
        <div>
          <div class="text-2xl font-black tracking-tighter mb-3" style="color: var(--accent)">
            {{ site.name }}
          </div>
          <p class="text-sm text-gray-400 leading-relaxed">{{ site.tagline }}</p>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">Εξυπηρέτηση</h4>
          <ul class="space-y-2 text-sm text-gray-500">
            <li><a href="#" class="hover:text-gray-900 transition-colors">Επικοινωνία</a></li>
            <li><a href="#" class="hover:text-gray-900 transition-colors">Επιστροφές</a></li>
            <li><a href="#" class="hover:text-gray-900 transition-colors">Αποστολές</a></li>
          </ul>
        </div>
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-widest text-gray-400 mb-4">Πληροφορίες</h4>
          <ul class="space-y-2 text-sm text-gray-500">
            <li><a href="#" class="hover:text-gray-900 transition-colors">Σχετικά με εμάς</a></li>
            <li><a href="#" class="hover:text-gray-900 transition-colors">Όροι χρήσης</a></li>
            <li><a href="#" class="hover:text-gray-900 transition-colors">Προστασία δεδομένων</a></li>
          </ul>
        </div>
      </div>
      <div class="mt-12 pt-8 border-t border-gray-50 flex flex-col sm:flex-row items-center
                  justify-between gap-3 text-xs text-gray-300">
        <span>&copy; {{ year }} {{ site.name }}. Όλα τα δικαιώματα διατηρούνται.</span>
        <span>{{ product_count }} προϊόντα &middot; {{ category_count }} κατηγορίες</span>
      </div>
    </div>
  </footer>

  <!-- Cart toast -->
  <div id="cart-toast"
    class="fixed bottom-6 right-6 bg-white rounded-2xl shadow-2xl border border-gray-100 p-4
           text-sm hidden z-50 flex items-center gap-3 max-w-xs">
    <div class="w-8 h-8 rounded-full flex items-center justify-center flex-shrink-0"
         style="background: var(--accent)">
      <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
      </svg>
    </div>
    <span id="cart-toast-text" class="font-medium text-gray-700">Προστέθηκε</span>
  </div>

  <script src="{{ static_root }}/catalog.js"></script>
  {% block scripts %}{% endblock %}
</body>
</html>
